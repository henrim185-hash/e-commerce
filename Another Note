// services/category_services.js - Gestion complète des erreurs DB

const handleDBError = (err, context) => {
    // Timeouts
    if (err.code === '57014') {
        throw new Error('Database query timeout - please retry')
    }

    // Violation de contrainte unique (duplicate key)
    if (err.code === '23505') {
        if (err.constraint === 'categories_name_key') {
            throw new Error('Category name already exists')
        }
        if (err.constraint === 'categories_slug_key') {
            throw new Error('Category slug already exists')
        }
        throw new Error('Duplicate entry')
    }

    // Violation de clé étrangère
    if (err.code === '23503') {
        throw new Error('Operation failed due to existing references')
    }

    // Check violation (constraint CHECK)
    if (err.code === '23514') {
        throw new Error('Data validation failed')
    }

    // Connexion refusée
    if (err.code === '08006' || err.code === '08001') {
        throw new Error('Database connection failed')
    }

    // Deadlock
    if (err.code === '40P01') {
        throw new Error('Database deadlock detected - please retry')
    }

    // Serialization failure
    if (err.code === '40001') {
        throw new Error('Please retry the operation')
    }

    // Syntax error dans la requête (bug de notre code)
    if (err.code === '42601') {
        console.error(`SQL Syntax error in ${context}:`, err)
        throw new Error('Internal database error')
    }

    // Erreur inconnue - logguer pour debug
    console.error(`Unhandled database error in ${context}:`, err)
    throw new Error('Database operation failed')
}



